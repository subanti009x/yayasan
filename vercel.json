{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "alias": [
    "yayasan-sekolah-cendekia.vercel.app"
  ],
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/admin", "dest": "/api/admin" },
    { "src": "/admin.php", "dest": "/api/admin" },
    { "src": "/articles", "dest": "/api/articles" },
    { "src": "/articles.php", "dest": "/api/articles" },
    { "src": "/sd", "dest": "/api/sd" },
    { "src": "/sd.php", "dest": "/api/sd" },
    { "src": "/smp", "dest": "/api/smp" },
    { "src": "/smp.php", "dest": "/api/smp" },
    { "src": "/smk", "dest": "/api/smk" },
    { "src": "/smk.php", "dest": "/api/smk" },
    { "src": "/tk-paud", "dest": "/api/tk-paud" },
    { "src": "/tk-paud.php", "dest": "/api/tk-paud" },
    { "src": "/losari-tk", "dest": "/api/losari-tk" },
    { "src": "/losari-tk.php", "dest": "/api/losari-tk" },
    { "src": "/losari-sd", "dest": "/api/losari-sd" },
    { "src": "/losari-sd.php", "dest": "/api/losari-sd" },
    { "src": "/rosari", "dest": "/api/rosari" },
    { "src": "/rosari.php", "dest": "/api/rosari" },
    { "src": "/faq", "dest": "/api/faq" },
    { "src": "/faq.php", "dest": "/api/faq" },
    { "src": "/kontak", "dest": "/api/kontak" },
    { "src": "/kontak.php", "dest": "/api/kontak" },
    { "src": "/artikel-(.+)", "dest": "/api/artikel?slug=$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/$", "dest": "/api/index" },
    { "src": "/index.php", "dest": "/api/index" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
